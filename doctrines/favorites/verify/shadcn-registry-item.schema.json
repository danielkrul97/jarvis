{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "Faithful reconstruction of https://ui.shadcn.com/schema/registry-item.json (raw file download was sandbox-blocked). Encodes the verified constraints: required=[name,type], the type enum, and files-item rules (path+type required; +target for registry:file/registry:page).",
  "type": "object",
  "required": ["name", "type"],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "registry:lib", "registry:block", "registry:component", "registry:ui",
        "registry:hook", "registry:theme", "registry:page", "registry:file",
        "registry:style", "registry:base", "registry:font", "registry:item"
      ]
    },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "author": { "type": "string" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "devDependencies": { "type": "array", "items": { "type": "string" } },
    "registryDependencies": { "type": "array", "items": { "type": "string" } },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "type"],
        "properties": {
          "path": { "type": "string" },
          "content": { "type": "string" },
          "target": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "registry:lib", "registry:block", "registry:component", "registry:ui",
              "registry:hook", "registry:theme", "registry:page", "registry:file",
              "registry:style", "registry:base", "registry:font"
            ]
          }
        },
        "if": { "properties": { "type": { "enum": ["registry:file", "registry:page"] } } },
        "then": { "required": ["path", "type", "target"] }
      }
    },
    "cssVars": { "type": "object" },
    "css": { "type": "object" },
    "envVars": { "type": "object" },
    "docs": { "type": "string" },
    "categories": { "type": "array", "items": { "type": "string" } },
    "meta": { "type": "object" }
  }
}
